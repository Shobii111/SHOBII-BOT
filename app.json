{
  "name": "SHOBII BOT",
  "description": "SHOBII BOT - WhatsApp Bot | Deploy karne ke liye ya rabta karen: +923270321760",
  "logo": "https://i.imgur.com/your-logo.png",
  "keywords": ["whatsapp", "bot", "shobii"],
  "env": {
    "SESSION_ID": {
      "description": "Apni Session ID yahan paste karen. Session lene ke liye rabta karen: +923270321760",
      "required": true
    },
    "BOT_NAME": {
      "description": "Bot ka naam",
      "value": "SHOBII BOT",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Owner ka WhatsApp number",
      "value": "923270321760",
      "required": false
    },
    "PREFIX": {
      "description": "Command prefix (. ya ! ya #)",
      "value": ".",
      "required": false
    },
    "MODE": {
      "description": "public = sab use karen | private = sirf owner",
      "value": "public",
      "required": false
    },
    "ANTI_LINK": {
      "description": "Group mein links block kare (true/false)",
      "value": "true",
      "required": false
    },
    "antidelete": {
      "description": "Delete messages dikhaye (all/off)",
      "value": "all",
      "required": false
    },
    "STATUSVIEW": {
      "description": "Auto status view (true/false)",
      "value": "true",
      "required": false
    },
    "AutoReaction": {
      "description": "Auto reaction on messages (true/false)",
      "value": "false",
      "required": false
    },
    "MENU_IMAGE": {
      "description": "Menu image ka URL (optional)",
      "value": "",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
